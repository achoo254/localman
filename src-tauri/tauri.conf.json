{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "localman",
  "version": "0.1.0",
  "identifier": "com.localman.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Localman",
        "width": 1280,
        "height": 800,
        "minWidth": 1280,
        "minHeight": 800,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM4MzI0QkE1QkQ4MjI3N0IKUldSN0o0SzlwVXN5T0JyQU5KUDRxQmR3d1NTUjU5bHV4RmpqdzlRMnYrR2ZBOU8zcitSMk94ZGkK",
      "endpoints": [
        "https://github.com/achoo254/localman/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Offline-first API client",
    "longDescription": "Localman — The API client that lives on your machine. Postman alternative with collections, environments, and local-first data.",
    "category": "DeveloperTool",
    "fileAssociations": [
      {
        "ext": ["json"],
        "mimeType": "application/json",
        "description": "JSON Collection File"
      }
    ]
  }
}
